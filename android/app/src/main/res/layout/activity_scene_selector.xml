<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a12"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/selector_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Elige modo de reproducción"
        android:textColor="#e0f2fe"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/selector_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:text="Reproductor nativo ExoPlayer (sin WebView)"
        android:textColor="#94a3b8"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scene_immersive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="VR" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scene_split"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Cine Live" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scene_mix"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Live Cam" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_selector_cancel"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar" />

</LinearLayout>
