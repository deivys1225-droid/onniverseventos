<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- WebView/WebRTC suele funcionar mejor con aceleración por hardware habilitada (por defecto true). -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <!--
      Sensores de movimiento (giroscopio + acelerómetro) para mirada con
      giroscopio en el lobby (LobbyDeviceOrientationLook, viewport único).
      `required="false"` deja entrar al APK aunque el dispositivo no los
      tenga (en ese caso el botón GIROSCOPIO no moverá la cámara).
    -->
    <uses-feature android:name="android.hardware.sensor.gyroscope" android:required="false" />
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <application
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!--
          Pantalla de inicio: solo MainActivity tiene MAIN + LAUNCHER.
          Capacitor Bridge carga index.html desde assets/public/ (npx cap sync copia el build web; equivale al www de Cordova).
        -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name="com.vivevr.app.MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            tools:ignore="GoogleAppIndexingWarning">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Google VR (Cardboard): expone la app como compatible con Cardboard. -->
                <category android:name="com.google.intent.category.CARDBOARD" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="onniverso" android:host="open" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="onniver" android:host="open-lobby" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.vivevr.app.SelectorActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBarLaunch" />

        <activity
            android:name="com.vivevr.app.PlayerActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:exported="false"
            android:theme="@style/AppTheme.NoActionBarLaunch" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Ajustes de sesión de audio típicos cuando el WebKit pide AUDIO_CAPTURE junto al micrófono -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!--
      Android 12+ (API 31): sin este permiso los sensores de movimiento
      (acelerómetro/giroscopio) están limitados a 200 Hz. Para que el
      head-tracking del modo VR estéreo (Cardboard) sea fluido (60 Hz
      objetivo), pedimos la tasa alta. Es un permiso "normal" (no requiere
      runtime request, Android lo concede al instalar el APK).
    -->
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!--
      Reproductor del Lobby (Pantalla 1) — selector de carpeta de MP3/MP4 en el dispositivo.
      Android 13+ (API 33+) usa permisos granulares por tipo de medio:
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Compatibilidad pre-Android 13: solo declarado hasta API 32 (en 33+ pasa al permiso granular). -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
</manifest>
