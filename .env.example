# Opcional: el cliente ya trae URL y clave publishable del proyecto por defecto.
# Usa este archivo solo si quieres otro proyecto o rotar claves (reinicia `npm run dev`).
# En Vercel: variables opcionales; sin ellas se usan los mismos valores por defecto del código.
#
# Supabase → Settings → API:
#   Project URL  → VITE_SUPABASE_URL (ej. https://xxxx.supabase.co)
#   anon public o publishable key → VITE_SUPABASE_PUBLISHABLE_KEY
# NUNCA pongas la service_role / secret en el frontend.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# También válido:
# VITE_SUPABASE_ANON_KEY=
