# Copia este archivo como ".env" en la raíz del proyecto y reinicia "npm run dev".
# En Vercel: Settings → Environment Variables (mismos nombres; redeploy obligatorio).
#
# Supabase → Settings → API:
#   Project URL  → VITE_SUPABASE_URL (ej. https://xxxx.supabase.co)
#   anon public o publishable key → VITE_SUPABASE_PUBLISHABLE_KEY
# NUNCA pongas la service_role / secret en el frontend.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# También válido:
# VITE_SUPABASE_ANON_KEY=
