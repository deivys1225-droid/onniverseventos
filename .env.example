# Opcional: el cliente puede usar valores por defecto embebidos.
# En Vercel: define VITE_SUPABASE_* si el proyecto no es el predeterminado del código.
#
# Supabase → Settings → API:
#   Project URL → VITE_SUPABASE_URL
#   anon / publishable → VITE_SUPABASE_PUBLISHABLE_KEY
# NUNCA pongas service_role ni LIVEPEER_API_KEY aquí: Livepeer solo en Supabase (secrets).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Live desde celular (Livepeer Studio + Edge Function):
# 1) https://livepeer.studio → Developers → API Keys → crea una clave nueva.
# 2) Supabase Dashboard → Edge Functions → Secrets → LIVEPEER_API_KEY = (pegar clave)
# 3) CLI: supabase link --project-ref TU_REF
#    npm run deploy:livepeer-fn
# 4) SQL: ejecuta migraciones del repo (incluye playback_url / playback_id en active_streams).

# También válido:
# VITE_SUPABASE_ANON_KEY=
